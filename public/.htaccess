RewriteEngine On

# Rediriger "/" vers "dashboard" (chemin relatif)
RewriteRule ^$ dashboard [R=301,L]

# Si la requête n'est pas un fichier existant ou un dossier
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tout rediriger vers index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
